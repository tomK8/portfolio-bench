<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      Daemonised: Logback writes to stdout; the start script redirects stdout/stderr
      to the log file. That way everything (Logback, System.out, System.err, JVM
      warnings) ends up in one tailable file.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
